# Copy this file to .env and replace the placeholder values with your real keys before running the app.
# Stripe API keys
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me

# Google Maps key for Android/iOS
GOOGLE_MAPS_API_KEY=replace_me

# Firebase service account used for FCM v1 access tokens
GCP_SERVICE_ACCOUNT_TYPE=service_account
GCP_SERVICE_ACCOUNT_PROJECT_ID=replace_me
GCP_SERVICE_ACCOUNT_PRIVATE_KEY_ID=replace_me
GCP_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nreplace_me\\n-----END PRIVATE KEY-----\\n"
GCP_SERVICE_ACCOUNT_CLIENT_EMAIL=replace_me@replace_me.iam.gserviceaccount.com
GCP_SERVICE_ACCOUNT_CLIENT_ID=replace_me
GCP_SERVICE_ACCOUNT_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GCP_SERVICE_ACCOUNT_TOKEN_URI=https://oauth2.googleapis.com/token
GCP_SERVICE_ACCOUNT_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GCP_SERVICE_ACCOUNT_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/replace-me.iam.gserviceaccount.com
GCP_SERVICE_ACCOUNT_UNIVERSE_DOMAIN=googleapis.com
